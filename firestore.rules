rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').lower() == 'motaem23y@gmail.com' ||
        request.auth.token.get('email', '').lower() == 'motaem23@gmail.com' ||
        request.auth.token.get('email', '').lower() == 'mazn74793@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidProject(data) {
      return data.keys().hasAll(['title', 'type', 'mediaUrl', 'createdAt', 'authorId']) &&
             data.title is string && data.title.size() <= 200 &&
             data.type in ['project', 'image', 'video'] &&
             data.mediaUrl is string && data.mediaUrl.size() <= 2000 &&
             data.authorId == request.auth.uid;
    }

    function isValidSetting(data) {
      return (data.schoolName is string && data.schoolName.size() <= 500) &&
             (!data.keys().hasAny(['logoUrl']) || (data.logoUrl is string && data.logoUrl.size() <= 5000)) &&
             (!data.keys().hasAny(['heroTitle']) || (data.heroTitle is string && data.heroTitle.size() <= 1000)) &&
             (!data.keys().hasAny(['heroSubtitle']) || (data.heroSubtitle is string && data.heroSubtitle.size() <= 1000)) &&
             (!data.keys().hasAny(['heroDescription']) || (data.heroDescription is string && data.heroDescription.size() <= 10000)) &&
             (!data.keys().hasAny(['aboutTitle']) || (data.aboutTitle is string && data.aboutTitle.size() <= 1000)) &&
             (!data.keys().hasAny(['aboutDescription']) || (data.aboutDescription is string && data.aboutDescription.size() <= 50000)) &&
             (!data.keys().hasAny(['aboutImageUrl']) || (data.aboutImageUrl is string && data.aboutImageUrl.size() <= 5000)) &&
             (!data.keys().hasAny(['directorName']) || (data.directorName is string && data.directorName.size() <= 500)) &&
             (!data.keys().hasAny(['directorVideoUrl']) || (data.directorVideoUrl is string && data.directorVideoUrl.size() <= 5000)) &&
             (!data.keys().hasAny(['directorPhotoUrl']) || (data.directorPhotoUrl is string && data.directorPhotoUrl.size() <= 5000));
    }

    function isValidAnnouncement(data) {
      return data.keys().hasAll(['title', 'content', 'type', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             data.type in ['info', 'urgent', 'event'];
    }

    // Admins collection
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        request.auth.token.get('email', '').lower() == 'motaem23y@gmail.com' ||
        request.auth.token.get('email', '').lower() == 'motaem23@gmail.com' ||
        request.auth.token.get('email', '').lower() == 'mazn74793@gmail.com'
      );
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProject(incoming());
      allow update: if (isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid)) && 
                      isValidProject(incoming());
      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
    }

    // Settings collection
    match /settings/{settingId} {
        allow read: if true;
        allow write: if isAdmin() && isValidSetting(incoming());
    }

    // Announcements collection
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin() && isValidAnnouncement(incoming());
    }
  }
}
