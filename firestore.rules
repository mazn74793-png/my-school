rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.type in ['project', 'image', 'video'] &&
             data.mediaUrl is string && data.mediaUrl.size() > 0 &&
             data.authorId == request.auth.uid;
    }

    function isValidSetting(data) {
        return data.schoolName is string && data.schoolName.size() > 0;
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true; // Publicly readable
      allow create: if isSignedIn() && isValidProject(request.resource.data);
      allow update: if isSignedIn() && isOwner(resource.data.authorId) && 
                     isValidProject(request.resource.data) &&
                     request.resource.data.authorId == resource.data.authorId;
      allow delete: if isSignedIn() && isOwner(resource.data.authorId);
    }

    // Settings collection
    match /settings/{settingId} {
        allow read: if true;
        allow write: if isSignedIn(); // For simplicity in this demo, any signed-in user can update if we don't have roles
    }
  }
}
