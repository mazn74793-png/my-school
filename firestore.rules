rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').toLower() == 'motaem23y@gmail.com' ||
        request.auth.token.get('email', '').toLower() == 'motaem23@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidProject(data) {
      return data.keys().hasAll(['title', 'type', 'mediaUrl', 'createdAt', 'authorId']) &&
             data.title is string && data.title.size() <= 200 &&
             data.type in ['project', 'image', 'video'] &&
             data.mediaUrl is string && data.mediaUrl.size() <= 2000 &&
             data.authorId == request.auth.uid;
    }

    function isValidSetting(data) {
      return data.schoolName is string && data.schoolName.size() <= 100;
    }

    // Admins collection
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.get('email', '').toLower() == 'motaem23y@gmail.com';
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProject(incoming());
      allow update: if (isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid)) && 
                      isValidProject(incoming());
      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
    }

    // Settings collection
    match /settings/{settingId} {
        allow read: if true;
        allow write: if isAdmin() && isValidSetting(incoming());
    }
  }
}
