rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').toLower() == 'motaem23y@gmail.com' ||
        request.auth.token.get('email', '').toLower() == 'motaem23@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    // Admins collection
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.get('email', '').toLower() == 'motaem23y@gmail.com';
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    // Settings collection
    match /settings/{settingId} {
        allow read: if true;
        allow write: if isAdmin();
    }
  }
}
