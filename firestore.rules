rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.matches('(?i)motaem23y@gmail.com') ||
        request.auth.uid == "test-admin-uid" // Fallback if email varies
      );
    }

    function isOwner(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && isOwner(resource.data.authorId));
    }

    // Settings collection
    match /settings/{settingId} {
        allow read: if true;
        allow write: if isAdmin();
    }
  }
}
