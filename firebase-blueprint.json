{
  "entities": {
    "Project": {
      "title": "Project or Achievement",
      "description": "Represents an entry in the portfolio, which could be a project, image, or video.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["project", "image", "video"] },
        "level": { "type": "string", "enum": ["primary", "preparatory", "secondary", "all"] },
        "mediaUrl": { "type": "string" },
        "techStack": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "type", "mediaUrl", "createdAt", "authorId"]
    },
    "Setting": {
        "title": "App Settings",
        "description": "Global application settings like school name, logo URL etc.",
        "type": "object",
        "properties": {
            "schoolName": { "type": "string" },
            "logoUrl": { "type": "string" },
            "heroTitle": { "type": "string" },
            "heroSubtitle": { "type": "string" },
            "heroDescription": { "type": "string" },
            "aboutTitle": { "type": "string" },
            "aboutDescription": { "type": "string" },
            "directorName": { "type": "string" },
            "aboutImageUrl": { "type": "string" }
        }
    },
    "Announcement": {
      "title": "School Announcement",
      "description": "Represents an announcement or decree published by the school admin.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "urgent", "event"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "type", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of all items shown on the website."
    },
    "/settings/{settingId}": {
        "schema": "Setting",
        "description": "Global settings for the portfolio."
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Collection of school announcements."
    }
  }
}
